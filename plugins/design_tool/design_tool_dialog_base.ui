        <property name="styleSheet">
            <string notr="true">/* Import Geist font */
QDialog {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 9pt;
}

QLabel {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-weight: 500;
}

QGroupBox {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-weight: 600;
    font-size: 9pt;
    border: 1px solid #c0c0c0;
    border-radius: 4px;
    margin-top: 10px;
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
}

QCheckBox {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-weight: 400;
}

QPushButton {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-weight: 500;
    background-color: #f0f0f0;
    border: 1px solid #c0c0c0;
    border-radius: 3px;
    padding: 5px 10px;
}

QPushButton:hover {
    background-color: #e0e0e0;
}

QPushButton:pressed {
    background-color: #d0d0d0;
}

QTextEdit {
    font-family: &quot;Geist Mono&quot;, &quot;Courier New&quot;, monospace;
    font-size: 8.5pt;
    background-color: #f8f8f8;
    border: 1px solid #c0c0c0;
    border-radius: 3px;
}

QProgressBar {
    font-family: &quot;Geist&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    border: 1px solid #c0c0c0;
    border-radius: 3px;
    text-align: center;
    background-color: #f0f0f0;
}

QProgressBar::chunk {
    background-color: #4CAF50;
    border-radius: 2px;
}</string>
